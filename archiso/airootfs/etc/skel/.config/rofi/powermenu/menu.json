{
  "name": "root",
  "type": "folder",
  "children": [
    {
      "name": "Close",
      "type": "close-prev-window",
      "icon": "window-close"
    },
    {
      "name": "Reboot",
      "type": "action",
      "icon": "system-reboot",
      "exec": "systemctl reboot"
    },
    {
      "name": "Suspend",
      "type": "action",
      "icon": "system-suspend",
      "exec": "hyprlock & sleep 1 && systemctl suspend"
    },
    {
      "name": "Shutdown",
      "type": "action",
      "icon": "system-shutdown",
      "exec": "systemctl poweroff"
    },
    {
      "name": "Logout",
      "type": "action",
      "icon": "system-log-out",
      "exec": "command -v hyprshutdown >/dev/null 2>&1 && hyprshutdown || hyprctl dispatch exit"
    },
    {
      "name": "Lock",
      "type": "action",
      "icon": "system-lock-screen",
      "exec": "hyprlock"
    }
  ]
}
