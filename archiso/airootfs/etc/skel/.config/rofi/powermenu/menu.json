{
  "name": "root",
  "type": "folder",
  "children": [
    {
      "name": "Close",
      "type": "close-prev-window",
      "icon": "window-close"
    },
    {
      "name": "Minimize",
      "type": "action",
      "icon": "minimize",
      "exec": "hyprland-minimizer"
    },
    {
      "name": "Pin",
      "type": "action",
      "icon": "pin",
      "exec": "~/.config/hypr/pip.sh"
    },
    {
      "name": "Swap with Master",
      "type": "action",
      "icon": "swap",
      "exec": "hyprctl dispatch 'hl.dsp.layout(\"swapwithmaster\", \"master\")'"
    },
    {
      "name": "Border Fullscreen",
      "type": "action",
      "icon": "view-fullscreen",
      "exec": "hyprctl dispatch 'hl.dsp.window.fullscreen({ mode = 1 })'"
    },
    {
      "name": "Exclusive Fullscreen",
      "type": "action",
      "icon": "view-fullscreen",
      "exec": "hyprctl dispatch 'hl.dsp.window.fullscreen({ mode = 0 })'"
    },
    {
      "name": "Lock",
      "type": "action",
      "icon": "system-lock-screen",
      "exec": "hyprlock"
    },
    {
      "name": "Suspend",
      "type": "action",
      "icon": "system-suspend",
      "exec": "hyprlock & sleep 1 && systemctl suspend"
    },
    {
      "name": "Shutdown",
      "type": "action",
      "icon": "system-shutdown",
      "exec": "systemctl poweroff"
    },
    {
      "name": "Reboot",
      "type": "action",
      "icon": "system-reboot",
      "exec": "systemctl reboot"
    },
        {
      "name": "Logout",
      "type": "action",
      "icon": "system-log-out",
      "exec": "loginctl terminate-session $XDG_SESSION_ID"
    }
  ]
}
