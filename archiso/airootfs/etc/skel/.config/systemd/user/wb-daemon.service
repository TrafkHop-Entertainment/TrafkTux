[Unit]
Description=TrafkTux Waybar Widget Daemon
After=graphical-session.target
PartOf=graphical-session.target

[Service]
Type=simple
# Pfad ggf. anpassen, falls die Skripte woanders liegen:
ExecStart=/usr/bin/python3 %h/.config/waybar/scripts/widgets_daemon.py
Restart=on-failure
RestartSec=1

[Install]
WantedBy=graphical-session.target
